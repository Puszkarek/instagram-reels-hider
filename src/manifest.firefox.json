{
  "manifest_version": 3,
  "name": "Instagram Reels Hider",
  "version": "__MSG_extVersion__",
  "description": "Hide Instagram reels from your feed and profile",
  "homepage_url": "https://github.com/Puszkarek/instagram-reels-hider",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Instagram Reels Hider",
    "default_popup": "popup/index.html"
  },
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "permissions": [
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "instagram-reels-hider@puszkarek.github.io",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "120.0a1"
    }
  },
  "content_scripts": [
    {
      "js": [
        "content/index.js"
      ],
      "matches": [
        "https://www.instagram.com/*"
      ]
    }
  ]
}